{
  "$schema": "https://opencode.ai/config.json",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "github-mcp-custom@1.0.20", "stdio"]
    },
    "jenkins": {
      "command": "/home/zhouwenguang/.local/bin/mcp-jenkins",
      "args": ["--jenkins-url", "http://localhost:8088"]
    },
    "k8s": {
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server"]
    }
  }
}
