{
  "$schema": "https://opencode.ai/config.json",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@github/github-mcp-server"],
      "env": {
        "GITHUB_TOKEN": ""
      }
    },
    "jenkins": {
      "command": "python3",
      "args": ["-m", "mcp_jenkins", "--jenkins-url", "http://localhost:8088"]
    },
    "k8s": {
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server"]
    }
  }
}
