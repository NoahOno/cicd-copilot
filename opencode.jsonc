{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "github-mcp-custom@1.0.20", "stdio"],
      "enabled": true
    },
    "jenkins": {
      "type": "local",
      "command": ["/home/zhouwenguang/.local/bin/mcp-jenkins", "--jenkins-url", "http://localhost:8088"],
      "enabled": true
    },
    "k8s": {
      "type": "local",
      "command": ["npx", "-y", "kubernetes-mcp-server"],
      "enabled": true
    }
  }
}
